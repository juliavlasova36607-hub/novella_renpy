label chapter_2:
    $ renpy.notify("Тот, кто помнит")

    # Локация: переход между секторами
    scene perexod with fade
    systemVoice "Предыстория"
    systemVoice "Полумрак коридора рассекали редкие лампы."
    systemVoice "Они отбрасывали длинные тени на металлические панели стен."
    systemVoice "Воздух здесь был суше, чем в архиве, пахнет иначе - не пылью и пергаментом, а
    металлом и статикой."
    e "Арен шёл, прислушиваясь к собственному дыханию."
    e "Каждый шаг отдавался глухим эхом."
    e "Будто пространство проверяло его на прочность."
    e "Вдруг — голос."

    iris "(Тихо, словно знала, что он услышит): Ты всё ещё считаешь паузы?"
    e "Арен резко остановился."
    e "Звук голоса ударил по нервам, словно забытый мотив из детства."
    e "Он обернулся."

    aren "(Насторожено): Мы знакомы?"
    systemVoice "Ирис Вальд стояла в полумраке, улыбаясь так, будто знала ответ задолго до вопроса."
    systemVoice "Её силуэт тонул в тени."
    systemVoice "Но глаза светились - не отражённым светом, словно в них тлели крошечные звёзды."

    iris "(Мягко, с лёгкой иронией): Дольше, чем ты думаешь."
    e "Тишина между словами растянулась, как резина."
    e "Арен почувствовал, как в груди зашевелилось что-то давнее — не воспоминание, а его тень."

    # Информация о Ирис
    systemVoice "Ирис — «хранительница переходов»."
    systemVoice "Её имя не значится ни в одном официальном реестре."
    systemVoice "но она появляется там, где границы между секторами истончаются."
    systemVoice "Она помнит то, что другие забывают, и забывает то, что другим нужно помнить."
    systemVoice "Её прошлое скрыто за семью печатями."

    menu:
        "Насторожиться":
            jump iris_alert
        "Довериться":
            jump iris_trust
        "Проверить":
            jump iris_test

label iris_alert:
    aren "(Шаг назад, голос твёрд): Откуда вы меня знаете?"
    iris "(Улыбаясь, но взгляд серьёзный): Потому что ты попросил меня помнить."
    e "Она подняла руку."
    e "На ладони лежал маленький предмет — не то медальон, не то кристалл, переливающийся всеми оттенками сумерек."
    aren "(Внутренний голос): Попросил? Когда? Почему я не помню?"
    iris "(Тихо): Ты боялся, что забудешь. Поэтому оставил мне ключ."
    systemVoice "Коридор вдруг наполнился шёпотом — тысячи голосов слившихся в один неразборчивый гул."
    systemVoice "Арен пошатнулся."
    systemVoice "Перед глазами вспыхнули обрывки:"
    systemVoice "Комната с высокими окнами, где дождь бьёт по стеклу..."
    systemVoice "рука, кладущая что-то в тёмный ящик..."
    systemVoice "Женский голос: «Когда забудешь — я помню…»"
    aren "(Шёпотом): Это… моё?"
    iris "(Улыбаясь): Теперь — да."
    jump chapter_2_end

label iris_trust:
    aren "(Делаю шаг вперёд, игнорируя внутренний голос кричавший:'Осторожно!'): Тогда расскажи."
    iris "(Покачав головой, голос звучит как колыбельная): Не сейчас. Ты не готов."
    aren "- А когда буду?"
    iris "(Оборачиваясь, взгляд скользит по металлическим панелям стены): Когда перестанешь бояться тишины."
    e "Она повернулась, чтобы уйти."
    e "Но Арен схватил её за рукав — ткань оказалась неожиданной тёплой, почти живой."
    aren "- Почему ты всегда говоришь загадками?"
    iris "(Мягко высвобождаясь, глаза вспыхивают на миг): Потому что правда — это не ответ. Это путь."
    e "В тот же миг коридор дрогнул, свет моргнул, и Ирис исчезла."
    e "Не растворилась, а будто шагнула за невидимую грань"
    aren "(Внутренний голос): Она знала что-то важное. Но почему не сказала?"
    e "В воздухе остался лишь слабый запах озона и ощущение, что где-то далеко захлопнулась дверь."
    e "Доверие открывает дверь в прошлое."
    e "Память начинает возвращаться, но фрагменты пока не складываются в картину."
    e "Арен понимает: Ирис — не случайная встреча, а часть его забытой истории."
    jump chapter_2_end

label iris_test:
    aren "(Твёрдо, глядя в глаза): Назовите что-то, что знаю только я."
    e "Его голос звучал твёрдо, но внутри всё сжалось. Что, если она ответит? Что, если не ответит?"
    systemVoice "Ирис медленно подняла глаза. В их глубине заплясали искры, складываясь в узоры, похожие на созвездия."
    iris "(Тихо, почти напевая): Ты боишься тишины больше, чем шума."

    # пауза

    e "(Пауза)"
    aren "(Внутренний голос): Это… правда. Но как она…"
    iris "(Шаг вперёд, голос становится  глубже): В пять лет ты заперся в шкафу, потому что за окном гремела гроза."
    iris "Ты считаешь секунды между молнией и громом, чтобы не слышать, как родители кричат друг на друга."
    e "Арен побледнел. Воспоминания хлынули потоком."
    e "...Теснота шкафа, запах нафталина..."
    e "...дрожащие пальцы, отсчитывающие: «Раз, два, три…»"
    e "...голос матери срывался на визг: «Ты даже ребёнка не можешь успокоить!»"
    aren "(С трудом): Никто… никто не знал об этом."
    iris "(Мягко, протягивая руку): Я знала. Потому что ты попросил."
    e "На её ладони лежал маленький ключ — такой же, как тот, что Марта Селл держала в архиве, но с гравировкой в виде спирали."
    e "Спираль на ключе символизирует «цикл памяти» — процесс, при котором воспоминания стираются и возвращаются."
    iris "Это твой страх. И твоя сила."
    e "«Коридор снова дрогнул. На этот раз Арен почувствовал, как под ногами меняется гравитация."
    e "Будто мир наклонился, открывая нову грань реальности.»"
    aren "(Шёпотом): Что ты такое?"
    iris "(Улыбаясь, глаза снова сверкают): Я — та, кто помнит."
    jump chapter_2_end

label chapter_2_end:
    e "Истинный флаг Ирис открыт."
    e "Арен знает: она связана с его прошлым."
    e "Но какова её роль? Почему он забыл то, что должен был помнить?"

    jump chapter_3