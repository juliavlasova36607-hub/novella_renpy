label chapter_1:

    $ renpy.notify("Пауза длиннее нормы")

    systemVoice "Предыстория."

    systemVoice "До Резонанса в Мере не боялись слов."

    systemVoice "После — начали бояться пауз."

    systemVoice "Когда люди начали искажать чужие воспоминания,
    правдой стало не то, что сказано,
    а то, что не было произнесено."

    systemVoice "Так появилась профессия —
    расшифровщик молчания."

    scene cabinet with fade

    e "Тишина в архиве была особенной.
    Не мёртвой, а наполненной.
    Она пульсировала, как живое существо."

    e "То затихала,
    то вновь наполнялась звуками,
    которые обычный человек не заметил бы."

    e "Марта Селл знала каждую ноту этой симфонии:
    шелест страниц,
    скрип старого паркета."

    e "И едва уловимое тиканье настенных часов
    с латунным маятником."

    e "Эти звуки служили ей компасом
    в мире забытых документов
    и запечатанных воспоминаний."

    e "Она сидела за массивным столом из тёмного дуба.
    Комнату освещала только лампа.
    Перед ней лежала стопка папок."

    e "На каждой стояла отметка:
    «Конфиденциально»."

    e "На стене висели старинные карты.
    На них были отметки,
    которых не существовало ни в одном атласе."

    e "Марта Селл работала архивариусом
    уже семнадцать лет."

    e "Когда-то она пришла сюда стажёркой,
    очарованная запахом старых бумаг
    и тайнами этих стен."

    e "Теперь она знала:
    архив — не просто хранилище документов."

    e "Это место,
    где время течёт иначе."

    e "Где прошлое не умирает,
    а лишь ждёт своего часа."

    e "Но сегодня всё было иначе."

    e "В воздухе чувствовалось
    чьё-то присутствие."

    e "Кто-то нарушил негласное правило:
    не входить в архив без приглашения."

    e "Дверь скрипнула."

    e "На пороге стоял Арен."

    marta "Вы уверены,
    что готовы приступить?"

    systemVoice "Её голос прозвучал ровно.
    Но в глазах мелькнуло сомнение,
    которое Арен уловил сразу."

    aren "(Мысли)
    Она задала вопрос слишком идеально.
    Такие вопросы задают, когда боятся ответа."

    systemVoice "Арен — исследователь аномалий.
    Он работает на границе официального
    и запретного."

    systemVoice "Его досье в центральном архиве
    имеет гриф:
    «Ограниченный доступ»."

    systemVoice "Он ищет то,
    что другие стараются скрыть."

    systemVoice "Исчезнувших людей.
    Необъяснимые события.
    Дыры в официальной истории."

    systemVoice "Его метод прост:
    слушать тишину."

    systemVoice "Он уверен —
    самые важные ответы звучат
    в паузах между словами."

    aren "(Мысли)
    Такие вопросы задают,
    когда боятся ответа."

    jump choice_menu_1


label choice_menu_1:

    menu:
        "Ответить сразу":
            jump answer_now

        "Продолжить молчать":
            jump stay_silent

        "Сменить тему":
            jump change_topic


label answer_now:

    aren "Да.
    Я готов."

    marta "Хорошо.
    Тогда пройдёмте."

    aren "(Мысли)
    Она ожидала сопротивления."

    aren "(Мысли)
    Но я его не дал."

    e "Доверие Марты немного растёт."

    jump route_after


label stay_silent:

    aren "..."

    e "Молчание растягивается.
    Марта ждёт.
    Её взгляд остаётся спокойным."

    marta "Время идёт.
    Вы готовы ответить?"

    menu:
        "Теперь ответить":
            jump answer_now_after_pause

        "Оставаться в молчании":
            jump deeper_silence


label change_topic:

    aren "Здесь всегда так тихо?"

    marta "Да."

    e "Пауза."

    marta "Не всегда."

    aren "(Мысли)
    Ошибка."

    aren "(Мысли)
    Значит, правда рядом."

    e "Тишина становится гуще."

    jump route_after


label answer_now_after_pause:

    aren "Да, я готов.
    Простите за паузу."

    marta "Принято."

    e "Марта становится
    чуть более настороженной."

    jump route_after


label deeper_silence:

    e "Тишина становится
    почти осязаемой."

    marta "Вижу.
    Вы предпочитаете слушать."

    aren "Именно."

    e "Марта воспринимает это
    как знак профессионального уважения."

    jump route_after


label route_after:

    $ renpy.notify("Они двинулись вглубь архива...")

    e "Они идут мимо стеллажей."

    e "Каждая папка хранит
    чью-то тайну."

    jump coridor


label coridor:

    scene coridor with fade

    $ renpy.notify("Вы оказались в коридоре")

    e "Они идут по узкому проходу."

    e "Свет ламп мерцает
    и не решается полностью
    рассеять тьму."

    marta "Квартира считается нежилой."

    aren "С самого начала?"

    e "Длинная пауза."

    marta "Да."

    aren "(Мысли)
    Слишком длинная пауза
    для простого ответа."

    aren "(Мысли)
    Она знает больше."

    jump apartment


label apartment:

    scene apartment with fade

    $ renpy.notify("Вы оказались в квартире")

    e "Комната пуста."

    e "Ни мебели,
    ни следов жизни."

    e "Только голые стены
    и окно с решёткой."

    aren "(Мысли)
    Но воздух помнит
    форму человека."

    aren "Здесь кто-то был."

    menu:
        "Сказать правду":
            jump tell_truth

        "Солгать":
            jump lie

        "Спросить Марту":
            jump ask_marta


label tell_truth:

    aren "Здесь кто-то был."

    marta "Этого
    не может быть."

    aren "Но было."

    marta "Тогда...
    всё повторяется."

    e "Доверие Марты
    колеблется."

    jump lie


label lie:

    aren "Нет.
    Пусто."

    marta "Хорошо."

    aren "(Мысли)
    Что-то ушло."

    e "В окне на миг
    появляется отражение."

    e "Но Арен
    не успевает его разглядеть."

    jump ask_marta


label ask_marta:

    aren "А вы
    что чувствуете?"

    marta "Я стараюсь
    не чувствовать."

    e "Тишина."

    e "Где-то далеко
    звенит стекло."

    e "Никто из них
    не двигается."


    e "Внезапно дверь
    распахивается."

    e "На пороге
    стоит женщина
    в сером плаще."

    e "Лина —
    координатор
    Сектора наблюдения."

    e "Её в узких кругах
    называют
    «Зеркалом»."

    lina "Вы превысили
    допустимое время."

    marta "Он
    имеет разрешение."

    lina "Я знаю."

    e "Лина делает шаг вперёд."

    e "В её руке
    блокнот
    с чёрной обложкой."

    lina "Вопрос
    в другом."

    lina "Зачем?"

    menu:
        "Ответить честно":
            jump answer_honestly

        "Уйти от ответа":
            jump avoid_answer

        "Промолчать":
            jump stay_silent_lina


label answer_honestly:

    aren "Потому что
    здесь кто-то исчез."

    lina "Интересно."

    e "Лина делает
    запись в блокноте."

    jump next_scene


label avoid_answer:

    aren "Потому что
    меня попросили."

    lina "Тогда
    будьте осторожны."

    e "В её голосе
    звучит предупреждение."

    jump next_scene


label stay_silent_lina:

    e "Длинная пауза."

    e "Часы
    на стене
    останавливаются."

    lina "Вы умеете
    пользоваться
    тишиной."

    e "Её блокнот
    слегка
    приоткрывается."

    jump next_scene


label next_scene:

    scene black

    $ renpy.notify("Продолжение следует...")

    jump chapter_2