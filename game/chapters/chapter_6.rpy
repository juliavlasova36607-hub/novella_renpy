label chapter_6:

    $ renpy.notify("Глава 6 — Последний выбор")

    scene pogranichie_mirow with dafe

    e "Пространство вокруг Арена не поддаётся осмыслению."
    e "Оно пульсирует, то сжимаясь до точки, то расширяясь в бесконечность."

    e "Нет ни верха, ни низа."
    e "Только мерцающие нити реальности."

    e "В воздухе запах озона и старой бумаги."
    e "Но теперь в нём чувствуется приближение бури."

    e "Арен стоит на краю бездны."

    e "Перед ним — дверь, которую он открыл."

    e "За ней — тьма."

    e "И тысячи глаз, наблюдающих за ним."

    systemVoice "Пограничье миров — место, где сталкиваются реальности."

    systemVoice "Здесь заканчивается путь хранителя."

    systemVoice "И начинается путь того, кто готов стать больше."

    aren "(Я помню всё.)"
    aren "(Но готов ли я?)"

    e "Перед ним появляются фигуры."

    marta "Ты не один."

    iris "Правда — это путь."

    lina "Ты знаешь, что делать."

    aren "Но если я ошибусь?"

    sirena "Ошибки — часть пути."

    sirena "Но выбор определит судьбу мира."

    menu:

        "Войти в дверь":
            jump ch6_enter

        "Закрыть дверь навсегда":
            jump ch6_close

        "Найти третий путь":
            jump ch6_third


# ВЕТКА 1 — СТРАЖ

label ch6_enter:

    aren "Я иду."

    eliana "Возвращайся..."

    aren "Я постараюсь."

    e "Он переступает порог."

    e "Дверь захлопывается."

    e "Тьма поглощает его."

    e "Но во тьме возникают образы."

    marta "Помни о договоре."

    iris "Равновесие."

    lina "Он сделал выбор."

    sirena "Ты — ключ."

    e "Тело Арена начинает меняться."

    e "Он больше не человек."

    e "Он — сущность света и тени."

    unknown "Ты принял вызов."

    unknown "Теперь ты страж Пограничья."

    aren "(Я не вернусь.)"

    aren "(Но я защищу этот мир.)"

    e "Перед ним появляется бесконечный коридор."

    e "Тысячи дверей."

    systemVoice "Он стал стражем."

    systemVoice "Последним хранителем границы."

    return


# ВЕТКА 2 — ЗАБВЕНИЕ

label ch6_close:

    aren "Я не могу."

    marta "Ты уверен?"

    aren "Да."

    e "Он протягивает руку."

    e "Дверь начинает закрываться."

    e "Но из неё вырывается свет."

    e "Перед ним появляется образ прошлого."

    e "Совет Хранителей."

    unknown "Если ты закроешь дверь..."

    unknown "Ты потеряешь себя."

    aren "Нет!"

    e "Дверь захлопывается."

    e "Тьма исчезает."

    e "Арен снова в зале вечных истин."

    e "Свиток превращается в пепел."

    eliana "Ты закрыл дверь."

    aren "Что я потерял?"

    sirena "Себя."

    aren "(Я... ничего не помню.)"

    e "Его тело начинает растворяться."

    systemVoice "Он закрыл дверь."

    systemVoice "Но потерял себя."

    systemVoice "Теперь он лишь тень между мирами."

    return


# ВЕТКА 3 — ИСТИННАЯ КОНЦОВКА

label ch6_third:

    aren "Есть другой путь."

    lina "Какой?"

    aren "Я изменю дверь."

    e "Он касается её."

    e "Дверь начинает меняться."

    e "Тьма превращается в свет."

    e "Глаза исчезают."

    e "Появляются образы друзей."

    marta "Ты сделал это."

    iris "Ты нашёл путь."

    lina "И он правильный."

    eliana "Я знала."

    unknown "Ты нашёл третий путь."

    unknown "Ты не хранитель."

    unknown "Ты творец."

    aren "Теперь я понимаю."

    sirena "Теперь ты знаешь."

    aren "Пусть миры будут связаны."

    aren "Но не смешаются."

    e "Дверь превращается в мост."

    e "Свет заполняет пространство."

    systemVoice "Он нашёл третий путь."

    systemVoice "Он превратил дверь в мост между мирами."

    jump ch6_return_scene


# ФИНАЛ

label ch6_return_scene:

    e "Свет постепенно гаснет."

    scene vozvrashenie with fade

    e "Арен стоит в архиве."

    e "Перед ним стол из тёмного дуба."

    e "На нём папки с пометкой: «Конфиденциально»."

    aren "Пора записать новую историю."

    e "Он берёт перо."

    systemVoice "История продолжается."

    systemVoice "Арен нашёл свой путь."

    systemVoice "Теперь он пишет новую главу."

    return