label chapter_1:  # label - без него
    # scene - фон, можешь и просто цветом прописать, а можешь просто название фото
    # show - имя персонажа итд
    # "Глава 1: Пауза длиннее нормы"  
    $ renpy.notify("Пауза длиннее нормы")

    systemVoice "Предыстория"

    systemVoice "До резонанса в Мере не боялись слов"

    systemVoice "После - начали бояться пауз"

    systemVoice "Когда люди начали искажать, чужие воспоминания, правдой стало не то, что сказано, а то, что не было произнесено"

    systemVoice "Так появилась профессия - расшифровшик молчания "

    e "Тишина в архиве была особенной - не мёртвой, а наполненой. Она пульсировала, как живое существо: то затихала, то вновь наполнялась звуками, которые обычный человек не заметил бы "

    e "Марта Селл знала каждую ноту этой симфонии - шелест перелистываемых страниц, скрип старого паркета, едва уловимое тиканье настенных часов с латунным маятником"

    e "Эти звуки служили ей компасом в мире забытых документов и запечатанных воспоминаний"
    
    e "Она сидела за массивным столом из тёмного дуба, освещённым лишь лампой. Перед ней лежала стопка папок с пометкой 'Конфиденцально'"

    e "На стене за спиной висели старинные карты с отметками, которых не было ни в одном официальном атласе"

    e "Марта Селл работала архивариусом уже 17 лет. Когда-то она пришла сюда как стажёрка, очарованная запахом старых бумаг  и тайной, которую хранили эти стены"

    e "Теперь же она знала: архив - не просто хранилище документов. это место, где время течёт иначе. Где прошлое не умирает, а ждёт своего часа"
     
    e "Но сегодня всё было иначе..."

    e "В воздухе витало что-то новое - не просто чужая энергия, а намеренное присутствие. Кто-то нарушил негласное правил: не входить не входить в архив без приглашения"

    e "Дверь скрипнула. На пороге стоял Арен"

    # show marta_sell at left

    marta "(Поднимая взгляд, холодно): Вы уверены, что готовы приступить?"

    systemVoice "Её голос прозвучал ровно, но в глазах мелькнуло нечто, что Арен уловил мгновенно"
 
    # show aren at right

    aren "(внутренний голос): Она задала вопрос идеально. Слишком идеально. Такие вопросы задают, когда боятся ответа"

    systemVoice "Арен - исследователь аномалий, работающий на грани официального и запретного. Его досье в центральных архивах помечено грифом ' Ограниченный доступ'"

    systemVoice "Он ищет то, что другие стараются скрыть: следы исчезнувших людей, необъяснимые события, дыры в официальной истории"

    systemVoice "Его - метод слушать тишну. Он уверен: самые важные ответы звучат не в слвах, а в паузах между ними"

    systemVoice "Арен стоял в полутёмном зале, ощущая как напряжение сковывает мышцы. Перед ним - Марта Селл, женщина с проницательным взглядом, будто читающие мысли. В воздухе витало ощущение решающего момента"

    aren "(Мысли): Такие вопросы задают, когда боятся ответа - прозвучало в тишине его мыслей, словно эхо чьих - то невысказанных страхов"

    jump choice_menu_1


# Разделить
# Первый выбор
label choice_menu_1:
    menu:
        "Ответить сразу":
            jump answer_now

        "Продолжить молчать":
            jump stay_silent

        "Сменить тему":
            jump change_topic

label answer_now:

    aren "Да. Я готов"

    marta "Хорошо. Тогда пройдёмте"

    aren "(Внутренний голос): Она ожидала сопротивления"

    aren "Я его не дал"

    e "Доверие Марты растёт. Тишина становится союзником"
    
    jump route_after


label stay_silent:

    aren "(Молчание растягивается. Марта ждёт, её взгляд не меняется)"
    
    aren "..."

    marta "Время идёт. Вы готовы ответить?"

    menu:
        "Теперь ответить":
            jump answer_now_after_pause

        "Оставаться в молчании":
            jump deeper_silence

label change_topic:

    aren "Здесь всегда так тихо?"

    marta "Да"

    e "пауза"

    marta "Не всегда"

    aren "(Внутренний голос): Ошибка"

    aren "Значит - правда рядом"

    e "Тишина становится гуще. Где-то вдали - едва уловимый шорох, будто кто - то перелистывает страницы"

    jump route_after

label answer_now_after_pause:
    aren "Да, я готов. Прошу прощения за заминку"

    marta "Принято"

    e "Молчание сыграло свою роль - теперь Марта чуть более насторожена"
    jump route_after

label deeper_silence:
    aren "(Тишина становится почти осязаемой. Марта слегла наклоняет голову, изучая его)"

    marta "Вижу. Вы предпочитаете слушать"

    aren "Именно так"

    e "Марта воспринимает это как знак профиссионального уважения"

    jump route_after

label route_after:
    $ renpy.notify("Они двинулись в глубь архива...")
    e "Они двинулись вглубь архива к выходу, мимо стеллажей с папками, каждая из которых хранила чью-то тайну..."

    jump coridor


#Разделить
# Сцена коридор 

label coridor:
    scene coridor with fade
    $ renpy.notify("Вы оказались в коридоре")

    e "Они идут по узкому проходу, свет ламп мерцает, будто не решается ролностью рассеять тьму"

    marta "Квартира считается нежилой"

    aren "С самого начала?"

    e "Длинная пауза"

    e "Марта замедляет шаг, но не останавливается"

    marta " Да"

    aren "(Внутренний голос): Слишком длинная пауза для простого 'да'. Она знает больше"

# Сцена квартира 

label apartment:
    scene apartment with fade
    $ renpy.notify("Вы оказались в квартире")

    e "Комната пуста. Ни мебели, ни следов быта. Только голый пол, голые стены и окно с решёткой."

    e "Но Арен чувствует: здесь было присутствие. Воздух хранит отпечаток человека - как запах, который нельзя уловить носом, но мощно ощутить..."
    
    marta "Как видите, здесь ничего нет"

    aren "(Внутренний голос): Воздух помнит форму человека"

    aren "Такое не путают"

    menu:
        "Сказать правду":
            jump tell_truth

        "Солгать":
            jump lie

        "Спросить Марту":
            jump ask_marta

label tell_truth:
    aren "Здесь кто-то был"

    marta "(Резко оборачиваясь,голос дрожит):Этого не может быть" 

    aren "(Шаг вперёд, глядя ей в глаза): Но было"

    marta "Тогда... Всё повторяется"

    e "Доверие Марты колеблется. Память пробуждается."

    e "В углу - тень, которой не должно быть"
    
    jump lie

label lie:
    aren "Нет. Пусто"

    marta "Хорошо"

    aren "Что-то ушло"

    aren "(Внутренний голос): Я позволил этому уйти"

    e "В окне на миг появляется отражение - чужой силуэт."

    e "Но Арен не успевает его разглядеть"

    jump ask_marta

label ask_marta:
    aren "А вы что чувствуете?"

    marta "Я стараюсь не чувствовать..."

    e "(Тишина)"

    e "Где-то далеко - звон разбитого стекла. Никто из них не двигается"

# Сцена повление Лины

    e "Внезапно дверь распахивается. На пороге - женщина в сером плаще. Её шаги не звучат. Она будто скользит по полу"

    e " Лина - координатор 'Сектора наблюдения'. Её должность официальность звучит как 'куратор архивных взаимодействий', но в узких кругах её называют 'зеркалом'."

    e "Она видит то, что другие пропускаю, и запоминает то, что другие стараются забыть"

    e "У неё нет прошлого в обычном понимании - только серия назначений и перемещений между секторами. Её досье в центральной базе данных содержит 17 пропусков в хронологии и отметку: «Доступ к информации ограничен по собственной инициативе"

    e "Её главный инструмент - блокнот с чёрной обложкой. Страницы в нём всегда пусты… пока она не решит, что кому‑то нужно что‑то увидеть"

    lina "(Холодно глядя на Арена): Вы превысили допустимое время"

    marta "(Резко с твердостью, шагнув вперёд): Он имеет разрешение"

    lina "(Улыбаясь,но следяными глаами): Я знаю"

    e "Пауза. Лина делает шаг вперёд. В её руке — маленький блокнот с чёрной обложкой. Страницы пусты, но Арен чувствует, как они шевелятся, будто живые. Воздух становится гуще, будто пропитан статикой. Марта незаметно сжимает ключ в кармане — тот самый, с гравировкой в виде перекрещённых перьев."

    lina "(Медленно, словно пробуя слова на вкус): Вопрос в другом. Зачем?"

    menu:
        "Ответить честно":
            jump answer_honestly
        
        "Уйти от ответа":
            jump avoid_answer
        
        "Промолчать":
            jump stay_silent_lina

label answer_honestly:
    aren "(Прямо не отводя взгляд): Потому что здесь кто-то исчез"

    lina "(Внимательно, чуть наклонив голову): Интересно"

    e "Внимание Лины сосредоточено. В блокноте появляется первая строка — но ни Арен, ни Марта не видят, что."

    jump next_scene  # Переход к следующей сцене

label avoid_answer:
    aren "(Спокойно, глядя ей в глаза, но не отступая): Потому что меня попросили"

    lina "(Кивает, блокнот остётся закрытым, но по его краям пробегает едва заметная искра): Тогда будьте осторожны"

    e "Нейтрально, но в её тоне слышится предупреждение. Марта делает незаметный шаг назад - она знает: когда Лина говорит «осторожно», это значит здесь опасно больше, чем ты думаешь."

    e "На стене за спиной Лины появляется трещина - тонкая, как волос, но она растёт, пока они разговаривают."

    e "В углу комнаты мелькнул силуэт - слишком быстрый, чтобы его можно было опознать."

    aren "(Мысли): Её «осторожность» звучит как карта минного поля. Кто её попросил? И почему я не помню, кто именно?"

    jump next_scene

label stay_silent_lina:
    e "Длинная пауза. Часы на стене останавливаются. Стрелки дрожат, будто пытаются сдвинуться, но не могут. В этом молчании слышно, как где‑то далеко капает вода - ритм совпадает с биением сердца Арена."

    lina "(Наклоняет голову, её тень на стене двигается независимо от неё): Вы умеете пользоваться тишиной."

    e "Внимание Лины сосредоточено. Её блокнот слегкатприоткрывается - на странице мелькает строка, но ни Арен, ни Марта не успевают её прочитать."

    e "Воздух становится плотным, как гель. Каждое движение требует усилий."

    e "Лина делает шаг вперёд, и её тень остаётся на месте, продолжая двигаться по стене."

    e "Марта незаметно достаёт из кармана маленький предмет - медальон с гравировкой 'S & L'."

    e "Она сжимает его в ладони, и тишина на миг становится тише."

    marta "(Мысли): 'Она проверяет его. Но зачем? И почему мне кажется, что я уже видела этот взгляд...'"

    aren "(Мысли): Тишина — это не отсутствие звука. Это язык, на котором говорят те, кто не хочет быть услышанным. И сейчас она говорит со мной."

    jump next_scene

label next_scene:
    scene blacks
    $ renpy.notify("Продолжение следует...")

    jump chapter_2
   
    return
